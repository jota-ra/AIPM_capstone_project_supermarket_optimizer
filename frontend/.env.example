# NOTE: this project keeps ONE .env at the repo root for both backend and
# frontend. Vite is configured to read it (envDir: '..' in vite.config.ts),
# so put these VITE_* vars in the repo-root .env — not here in frontend/.
# Only VITE_-prefixed vars are exposed to the browser; the service-role
# SUPABASE_KEY in the same file stays server-only.
#
# On Vercel, set these as Project Environment Variables instead
# (Settings -> Environment Variables); VITE_API_BASE_URL points at the
# deployed Render backend URL, e.g. https://nutriwise-backend.onrender.com

VITE_API_BASE_URL=http://localhost:8000

# E1 auth (Supabase). Public, browser-safe values — the anon key is
# designed to ship to the client (RLS + the backend JWT check protect
# data). Find them in your Supabase project: Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
